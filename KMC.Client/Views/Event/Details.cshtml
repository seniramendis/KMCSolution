@model KMC.Client.Models.EventViewModel
@{ ViewData["Title"] = Model.Title; }

<div class="container mt-5">
    <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">&larr; Back to Events</a>

    @if (TempData["Message"] != null)
    {
        var isSuccess = TempData["Success"]?.ToString() == "True";
        <div class="alert @(isSuccess ? "alert-success" : "alert-danger")">
            @TempData["Message"]
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <span class="badge bg-primary mb-2">@Model.Category</span>
            <h1 class="display-5 fw-bold">@Model.Title</h1>
            <p class="text-muted">Organized by @Model.OrganizerName</p>
            <hr />
            <h4 class="mt-4">About this event</h4>
            <p style="white-space: pre-wrap; font-size: 1.1rem;">@Model.Description</p>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm p-4 sticky-top" style="top: 20px;">
                <h5 class="mb-3">Event Details</h5>
                <p><strong><i class="bi bi-calendar"></i> Date:</strong> @Model.EventDate.ToString("MMMM dd, yyyy")</p>
                <p><strong><i class="bi bi-clock"></i> Time:</strong> @Model.EventDate.ToString("hh:mm tt")</p>
                <p><strong><i class="bi bi-geo-alt"></i> Location:</strong> @Model.Location</p>
                <hr />
                <p class="mb-2"><strong>Availability:</strong> @Model.SpotsLeft spots remaining</p>
                <div class="progress mb-4" style="height: 10px;">
                    @{ var pct = (Model.RegisteredCount * 100) / (Model.Capacity > 0 ? Model.Capacity : 1); }
                    <div class="progress-bar bg-success" style="width: @pct%;"></div>
                </div>

                @if (Model.SpotsLeft > 0)
                {
                    <form asp-controller="Event" asp-action="Register" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-primary w-100 btn-lg">Register Now</button>
                    </form>
                }
                else
                {
                    <button class="btn btn-secondary w-100 btn-lg" disabled>Sold Out</button>
                }
            </div>
        </div>
    </div>
</div>