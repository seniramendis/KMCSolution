@model KMC.Client.Models.CreateEventViewModel
@{ ViewData["Title"] = "Create Event"; }

<div class="container mt-5" style="max-width: 600px;">
    <h2 class="mb-4">Create New Event</h2>

    <form asp-action="Create" method="post" class="card p-4 shadow-sm">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <div class="mb-3">
            <label class="form-label fw-bold">Event Title</label>
            <input asp-for="Title" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Category</label>
                <select asp-for="Category" class="form-select" required>
                    <option value="Music">Music</option>
                    <option value="Sports">Sports</option>
                    <option value="Culture">Culture</option>
                    <option value="Business">Business</option>
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Date & Time</label>
                <input asp-for="EventDate" type="datetime-local" class="form-control" required />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Location</label>
                <input asp-for="Location" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Max Capacity</label>
                <input asp-for="Capacity" type="number" class="form-control" min="1" value="100" required />
            </div>
        </div>

        <div class="d-flex justify-content-between mt-3">
            <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-success">Publish Event</button>
        </div>
    </form>
</div>