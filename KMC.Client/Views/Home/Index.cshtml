@model IEnumerable<KMC.Client.Models.EventViewModel>
@{ ViewData["Title"] = "Home"; }

<div class="container mt-4">
    <div class="p-5 mb-4 bg-dark text-white rounded-3 text-center shadow">
        <h1 class="display-4 fw-bold">Discover Kandy's Best Events</h1>
        <p class="col-md-8 mx-auto fs-5 mt-3">From vibrant cultural festivals to local sports tournaments, find your next experience in the heart of the hill capital.</p>
    </div>

    <form method="get" class="row g-2 mb-5 justify-content-center">
        <div class="col-auto">
            <select name="category" class="form-select">
                <option value="">All Categories</option>
                <option value="Music">Music</option>
                <option value="Sports">Sports</option>
                <option value="Culture">Culture</option>
                <option value="Business">Business</option>
            </select>
        </div>
        <div class="col-auto">
            <input type="date" name="date" class="form-control" value="@ViewBag.Date" />
        </div>
        <div class="col-auto">
            <input type="text" name="location" class="form-control" placeholder="Search Location..." value="@ViewBag.Location" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary px-4">Search</button>
        </div>
    </form>

    <h2 class="mb-4">Upcoming Events</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-secondary text-center py-5">
            <h4>No events found</h4>
            <p>Try adjusting your search filters or check back later!</p>
            <a asp-action="Index" class="btn btn-outline-secondary mt-2">Clear Filters</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var ev in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="badge bg-primary">@ev.Category</span>
                                @if (ev.SpotsLeft <= 0)
                                {
                                    <span class="badge bg-danger">Sold Out</span>
                                }
                            </div>
                            <h4 class="card-title fw-bold">@ev.Title</h4>
                            
                            <div class="mt-3 text-muted">
                                <p class="mb-1"><strong><i class="bi bi-calendar"></i> Date:</strong> @ev.EventDate.ToString("MMM dd, yyyy - HH:mm")</p>
                                <p class="mb-0"><strong><i class="bi bi-geo-alt"></i> Location:</strong> @ev.Location</p>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center pb-3">
                            <span class="text-success fw-bold small">@ev.SpotsLeft spots left</span>
                            <a asp-controller="Event" asp-action="Details" asp-route-id="@ev.Id" class="btn btn-outline-primary btn-sm px-3">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>