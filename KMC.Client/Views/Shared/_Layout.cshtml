@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KMC Events</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-4 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary fs-4" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-calendar-event"></i> KMC Events
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                    </ul>
                    
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("JwtToken") != null)
                        {
                            if (Context.Session.GetString("Role") == "Organizer")
                            {
                                <li class="nav-item"><a class="nav-link fw-semibold" asp-controller="Event" asp-action="Dashboard">Dashboard</a></li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link fw-semibold" asp-controller="Event" asp-action="MyRegistrations">My Tickets</a></li>
                            }
                            <li class="nav-item ms-3">
                                <a class="btn btn-outline-danger btn-sm mt-1" asp-controller="Auth" asp-action="Logout">Logout (@Context.Session.GetString("FullName"))</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link fw-semibold" asp-controller="Auth" asp-action="Login">Login</a></li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-primary btn-sm mt-1 px-3" asp-controller="Auth" asp-action="Register">Get Started</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>