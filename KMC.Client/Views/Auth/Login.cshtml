@model KMC.Client.Models.LoginViewModel
@{ ViewData["Title"] = "Log In"; }

<div class="container section">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="form-card">
                <h2 class="mb-4 text-center">Welcome Back</h2>
                
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success">@TempData["Message"]</div>
                }
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    <div class="field mb-3">
                        <label asp-for="Email" class="label">Email</label>
                        <input asp-for="Email" type="email" class="input" required />
                    </div>
                    <div class="field mb-4">
                        <label asp-for="Password" class="label">Password</label>
                        <input asp-for="Password" type="password" class="input" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Log In</button>
                </form>
                <div class="text-center mt-3">
                    <a asp-action="Register">Need an account? Register</a>
                </div>
            </div>
        </div>
    </div>
</div>