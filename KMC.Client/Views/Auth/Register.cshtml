@model KMC.Client.Models.RegisterViewModel
@{ ViewData["Title"] = "Register"; }

<div class="container section">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="form-card">
                <h2 class="mb-4 text-center">Create an Account</h2>
                
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="Register" method="post">
                    <div class="field mb-3">
                        <label asp-for="FullName" class="label">Full Name</label>
                        <input asp-for="FullName" class="input" required />
                    </div>
                    <div class="field mb-3">
                        <label asp-for="Email" class="label">Email Address</label>
                        <input asp-for="Email" type="email" class="input" required />
                    </div>
                    <div class="field mb-3">
                        <label asp-for="Password" class="label">Password</label>
                        <input asp-for="Password" type="password" class="input" required />
                    </div>
                    <div class="field mb-4">
                        <label asp-for="Role" class="label">Account Type</label>
                        <select asp-for="Role" class="select">
                            <option value="Public">General Public (Attendee)</option>
                            <option value="Organizer">Event Organizer</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Register</button>
                </form>
                <div class="text-center mt-3">
                    <a asp-action="Login">Already have an account? Log in</a>
                </div>
            </div>
        </div>
    </div>
</div>